        "color": "#2d70b3",
        "latex": "R\\left(0.25\\right)"
      },
      {
        "type": "folder",
        "id": "38",
        "title": "Lagrange Error Bound",
        "collapsed": true
      },
      {
        "type": "text",
        "id": "43",
        "folderId": "38",
        "text": "M is the maximum absolute value of the nth derivative of f between x and c"
      },
      {
        "type": "expression",
        "id": "39",
