    "list": [
      {
        "type": "folder",
        "id": "49",
        "title": "Cone and Plane",
        "collapsed": true
      },
      {
        "type": "text",
        "id": "52",
        "folderId": "49",
        "text": "Cone with beta value"
      },
      {
        "type": "expression",
        "id": "1",
        "folderId": "49",
        "color": "#3aaaa3",
        "latex": "r=z\\tan\\beta",
        "polarDomain": {
          "min": "0",
          "max": ""
        }
      },
      {
        "type": "text",
        "id": "54",
        "folderId": "49",
        "text": "Slicing plane"
      },
      {
        "type": "expression",
        "id": "39",
        "folderId": "49",
        "color": "#aaaaaa",
        "latex": "z=f\\left(x\\right)",
        "extendTo3D": true
      },
      {
        "type": "text",
        "id": "56",
        "folderId": "49",
        "text": "Intersection of plane and cone"
      },
      {
        "type": "expression",
        "id": "41",
        "folderId": "49",
        "color": "#fa7e19",
        "latex": "r=z\\tan\\beta\\ \\left\\{z=f\\left(x\\right)\\right\\}"
      },
      {
        "type": "text",
        "id": "58",
        "folderId": "49",
        "text": "Plane eq: z = f(x)"
      },
      {
        "type": "text",
        "id": "65",
        "folderId": "49",
        "text": "m is the \"slope\" of the plane"
      },
      {
        "type": "expression",
        "id": "63",
        "folderId": "49",
        "color": "#c74440",
        "latex": "m_{plane}=\\cot\\left(\\arccos\\left(e_{ccentricity}\\ \\cos\\beta\\right)\\right)"
      },
      {
        "type": "expression",
        "id": "44",
        "folderId": "49",
        "color": "#2d70b3",
        "latex": "f\\left(x\\right)=\\left(x-x_{shift}\\right)m_{plane}+z_{shift}",
        "hidden": true
      },
      {
        "type": "text",
        "id": "62",
        "text": "β: Half of cone width (default π/4)"
      },
      {
        "type": "expression",
        "id": "50",
        "color": "#2d70b3",
        "latex": "\\beta=0.785398163397",
        "hidden": true,
        "slider": {
          "hardMin": true,
          "hardMax": true,
          "min": "0",
          "max": "\\frac{\\pi}{2}-0.1"
        }
      },
      {
        "type": "text",
        "id": "67",
        "text": "e = 0:       circle\n0 < e < 1: ellipse\ne = 1:       parabola\ne > 1:       hyperbola"
      },
      {
        "type": "expression",
        "id": "43",
        "color": "#c74440",
        "latex": "e_{ccentricity}=1",
        "slider": {
          "hardMin": true,
          "hardMax": true,
          "min": "0",
          "max": "\\sec\\beta"
        }
      },
      {
        "type": "text",
        "id": "60",
        "text": "Shift the plane around"
      },
      {
        "type": "expression",
        "id": "42",
